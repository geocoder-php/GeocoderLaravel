{
    "name": "toin0u/geocoder-laravel",
    "description": "Geocoder Service Provider for Laravel",
    "keywords": [
        "laravel",
        "geocoder",
        "geocoding"
    ],
    "homepage": "http://geocoder-php.org/",
    "license": "MIT",
    "authors": [
        {
            "name": "Mike Bronner",
            "email": "hello@genealabs.com",
            "homepage": "https://genealabs.com",
            "role": "Developer, Maintainer"
        },
        {
            "name": "Antoine Corcy",
            "email": "contact@sbin.dk",
            "homepage": "http://sbin.dk",
            "role": "Original Creator"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4|^8.5",
        "geocoder-php/chain-provider": "^4.0|^5.0",
        "geocoder-php/geo-plugin-provider": "^4.0|^5.0",
        "geocoder-php/google-maps-provider": "^4.0|^5.0",
        "guzzlehttp/psr7": "*",
        "http-interop/http-factory-guzzle": "^1.0",
        "illuminate/cache": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "php-http/curl-client": "*",
        "willdurand/geocoder": "^4.0|^5.0"
    },
    "require-dev": {
        "doctrine/dbal": "*",
        "geocoder-php/bing-maps-provider": "^4.0",
        "geocoder-php/geoip2-provider": "^4.0",
        "geocoder-php/maxmind-binary-provider": "^4.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "orchestra/testbench-browser-kit": "^9.0|^10.0|^11.0",
        "orchestra/testbench-dusk": "^9.0|^10.0|^11.0",
        "php-coveralls/php-coveralls": "*",
        "phpunit/phpunit": "^10.5|^11.5.3|^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "Geocoder\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\": "vendor/laravel/laravel/app/",
            "Geocoder\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Geocoder\\Laravel\\Providers\\GeocoderService"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
