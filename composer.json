{
    "name": "toin0u/geocoder-laravel",
    "description": "Geocoder Service Provider for Laravel",
    "keywords": [
        "laravel",
        "geocoder",
        "geocoding"
    ],
    "homepage": "http://geocoder-php.org/",
    "license": "MIT",
    "authors": [
        {
            "name": "Mike Bronner",
            "email": "hello@genealabs.com",
            "homepage": "https://genealabs.com",
            "role": "Developer, Maintainer"
        },
        {
            "name": "Antoine Corcy",
            "email": "contact@sbin.dk",
            "homepage": "http://sbin.dk",
            "role": "Original Creator"
        }
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:mikebronner/development-settings.git"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4|^8.5",
        "geocoder-php/chain-provider": "^4.0|^5.0",
        "geocoder-php/geo-plugin-provider": "^4.0|^5.0",
        "geocoder-php/google-maps-provider": "^4.0|^5.0",
        "guzzlehttp/psr7": "*",
        "http-interop/http-factory-guzzle": "^1.0",
        "illuminate/cache": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "willdurand/geocoder": "^4.0|^5.0"
    },
    "require-dev": {
        "geocoder-php/bing-maps-provider": "^4.0",
        "geocoder-php/geoip2-provider": "^4.0",
        "geocoder-php/maxmind-binary-provider": "^4.0",
        "geocoder-php/nominatim-provider": "^5.0",
        "larastan/larastan": "^3.5",
        "laravel/boost": "^2.4",
        "laravel/pint": "^1.24",
        "mikebronner/development-settings": "^0.1",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "slevomat/coding-standard": "^8.24"
    },
    "autoload": {
        "psr-4": {
            "Geocoder\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Geocoder\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Geocoder\\Laravel\\Providers\\GeocoderService"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "mikebronner/development-settings": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    }
}
